{
  "name": "trivo-technical-assignment",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "db:generate:api": "npm run db:generate -w apps/api",
    "db:push:api": "npm run db:push -w apps/api",
    "db:seed:api": "npm run db:seed -w apps/api",
    "db:setup:api": "npm run db:generate:api && npm run db:push:api && npm run db:seed:api",
    "build:web": "npm run build -w apps/web",
    "lint:web": "npm run lint -w apps/web",
    "typecheck:web": "npm run typecheck -w apps/web",
    "lint": "npm run lint:web",
    "typecheck": "npm run typecheck:web"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
